const numero = parseInt(prompt("Digite um número inteiro e positivo: "));

if (numero <= 0) {
    console.log("ERRO! Digite um número inteiro e positivo!");
} else {
    let fatorial = 1;

    for (let i = 1; i <= numero; i++) {
        fatorial *= i;
    }

    console.log(`O fatorial de ${numero} é: ${fatorial}`);
}
